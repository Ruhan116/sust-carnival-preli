# QueueStorm Investigator — environment variables
# Copy to `.env` and fill in values. NEVER commit a real key (.env is git-ignored).
# The service runs fully (rules-only) even with everything below unset.

# Google Gemini API key. Optional — enables the LLM reasoning/refinement layer.
# Leave unset (or set LLM_MODE=off) to run the deterministic rule engine only.
GEMINI_API_KEY=

# LLM behavior: "decide" (LLM authoritative, rules are the fallback),
# "enhance" (LLM only polishes prose), or "off" (rules only). Default: decide
LLM_MODE=decide

# Gemini model id. Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Hard per-call timeout (seconds) so a slow LLM never breaches the 30s SLA. Default: 20
LLM_CALL_TIMEOUT_S=20

# Cooldown (seconds) after a rate-limit/quota error before retrying the LLM. Default: 15
LLM_COOLDOWN_S=15
